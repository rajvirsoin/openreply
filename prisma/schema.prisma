// ManyChat Alternative — B2B Instagram Comment → DM SaaS schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers  WorkspaceMember[]
  sentInvitations   WorkspaceInvitation[] @relation("WorkspaceInvitationsSent")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usagePeriodStart  DateTime @default(now())
  dmsSentThisPeriod Int      @default(0)

  members           WorkspaceMember[]
  invitations       WorkspaceInvitation[]
  instagramAccounts InstagramAccount[]
  automations       Automation[]
  dmLogs            DmLog[]
  trackedLinks      TrackedLink[]
  linkClicks        LinkClick[]
  webhookEvents     WebhookEvent[]
  operationalEvents OperationalEvent[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id              String                    @id @default(cuid())
  workspaceId     String
  email           String
  role            WorkspaceRole             @default(MEMBER)
  token           String                    @unique
  status          WorkspaceInvitationStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("WorkspaceInvitationsSent", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, email])
  @@index([email])
  @@index([workspaceId])
  @@index([status])
}

model InstagramAccount {
  id                String   @id @default(cuid())
  workspaceId       String
  instagramId       String   @unique
  username          String
  name              String?
  accessToken       String
  tokenExpiresAt    DateTime?
  webhookSubscribed Boolean  @default(false)
  connectedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automations Automation[]
  dmLogs      DmLog[]
  linkClicks  LinkClick[]

  @@index([workspaceId])
}

model Automation {
  id                 String   @id @default(cuid())
  workspaceId        String
  instagramAccountId String

  name           String
  goal           String?
  postId         String?
  postUrl        String?
  pendingNextReel Boolean @default(false)
  matchAnyPost   Boolean @default(false)
  keywords       String[]
  matchAnyWord   Boolean @default(false)
  dmMessage      String
  openingDmEnabled     Boolean @default(false)
  openingDmMessage     String?
  openingDmButtonLabel String?
  linkButtonLabel      String?
  publicReplyEnabled Boolean @default(false)
  publicReplyMessage String?
  publicReplyMessages String[] @default([])
  isActive       Boolean @default(true)
  wholeWordMatch Boolean @default(true)
  reportShareSlug    String? @unique
  reportShareEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  dmLogs           DmLog[]
  trackedLinks     TrackedLink[]
  linkClicks       LinkClick[]

  @@index([workspaceId])
  @@index([instagramAccountId])
  @@index([postId])
}

model DmLog {
  id                 String     @id @default(cuid())
  workspaceId        String
  automationId       String
  instagramAccountId String

  commenterId   String
  commenterName String?
  commentText   String
  commentId     String
  matchedKeyword String?
  status        DmStatus @default(PENDING)
  attempts      Int      @default(0)
  dmSentAt      DateTime?
  errorMessage  String?

  // The public comment reply is delivered independently of the DM, so its
  // outcome is tracked separately. publicReplySentAt makes it idempotent across
  // retries; a DM failure never blocks or re-posts the public reply.
  publicReplySentAt DateTime?
  publicReplyError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automation       Automation       @relation(fields: [automationId], references: [id], onDelete: Cascade)
  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([automationId, commentId])
  @@index([workspaceId])
  @@index([automationId])
  @@index([instagramAccountId])
  @@index([status])
}

// Every comment the system has seen, from either the webhook or the polling
// reconciler. This is the shared dedup set: a comment id present here has
// already been queued for processing, so neither path acts on it twice. It is
// distinct from DmLog (which only records comments that matched a campaign);
// this records all comments so the reconciler doesn't re-sweep non-matching
// ones every cycle.
model ProcessedComment {
  id                 String   @id @default(cuid())
  instagramAccountId String
  commentId          String   @unique
  source             String // "WEBHOOK" | "POLLING"
  seenAt             DateTime @default(now())

  @@index([instagramAccountId])
}

model TrackedLink {
  id             String   @id @default(cuid())
  workspaceId    String
  automationId   String
  slug           String   @unique
  label          String?
  destinationUrl String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automation Automation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  clicks     LinkClick[]

  @@index([workspaceId])
  @@index([automationId])
}

model LinkClick {
  id                 String   @id @default(cuid())
  workspaceId        String
  automationId       String
  instagramAccountId String
  trackedLinkId      String
  ipHash             String?
  userAgent          String?
  referrer           String?
  createdAt          DateTime @default(now())

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automation       Automation       @relation(fields: [automationId], references: [id], onDelete: Cascade)
  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  trackedLink      TrackedLink      @relation(fields: [trackedLinkId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([automationId])
  @@index([instagramAccountId])
  @@index([trackedLinkId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

model WebhookEvent {
  id          String        @id @default(cuid())
  workspaceId String?
  object      String?
  payload     Json
  status      WebhookStatus @default(PENDING)
  errorMessage String?
  createdAt   DateTime      @default(now())
  processedAt DateTime?

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
}

model OperationalEvent {
  id          String                @id @default(cuid())
  workspaceId String?
  source      OperationalEventSource
  level       OperationalEventLevel @default(INFO)
  message     String
  payload     Json?
  createdAt   DateTime              @default(now())
  resolvedAt  DateTime?

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([source])
  @@index([level])
  @@index([createdAt])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum DmStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_DEDUP
  SKIPPED_RATE_LIMIT
  SKIPPED_PLAN_LIMIT
  SKIPPED_NO_MATCH
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum OperationalEventSource {
  WORKER
  TOKEN_REFRESH
  HEALTH
  SYSTEM
}

enum OperationalEventLevel {
  INFO
  WARNING
  ERROR
}
